{
  "manifest_version": 3,
  "name": "Websears Summarizer",
  "version": "1.0.0",
  "description": "Summarize any page instantly using your local AI models or cloud APIs.",

  "permissions": ["sidePanel", "activeTab", "scripting", "storage", "tabs"],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "side_panel": {
    "default_path": "index.html"
  },

  "action": {
    "default_title": "Open Websears Summarizer"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}